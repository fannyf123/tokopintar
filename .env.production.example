# Production env example for Render deploy.
# Render will inject DB_* from the linked database, APP_KEY auto-generated.
APP_NAME=TOKOPINTAR
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_LOCALE=id

LOG_CHANNEL=stderr
LOG_LEVEL=warning

SESSION_DRIVER=database
CACHE_STORE=database
QUEUE_CONNECTION=database

DB_CONNECTION=pgsql
FILESYSTEM_DISK=public
PORT=8080
